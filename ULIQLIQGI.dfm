        Font.Style = []
        Lines.Strings = (
          
            'DECLARO FORMALMENTE BAJO PROTESTA Y SIN PRESION FISICA NI MORAL ' +
            'ALGUNA QUE EL FALTANDE DE $  QUE SE REFLEJA EN EL PRESENTE DOCUM' +
            'ENTO ES A MI CARGO Y QUE NO TUVE LA POSIBILIDAD DE JUSTIFICARLO ' +
            'POR LO QUE, DICHA CANTIDAD SE LA ADEUDO A LA EMPRESA EN SU TOTAL' +
            'IDAD Y, LA FACULTO PARA QUE SI ASI LO DESEA RESCINDA DE MI CONTR' +
            'ATO POR FALTA DE PROBIDAD Y CON FUNDAMENTO EN LA FRACCION II DEL' +
            ' ARTICULO 47 DE LA LEY FEDERAL DEL TRABAJO EN VIGOR.'
          ''
          
            'ASIMISMO MANIFIESTO EN LOS MISMOS TERMINOS QUE TODAS Y CADA UNA ' +
            'DE LAS CANTIDADES QUE APARECEN EN ESTE DOCUMENTO SON REALES Y FU' +
            'ERON PORMENORIZADAMENTE ANALIZADOS POR MI.')
        ParentFont = False
        Transparent = False
        WordWrap = True
        FontSize = 7
      end
