  object QL_TranUpdate: TUpdateSQL
    ModifySQL.Strings = (
      'update DGASTRAN'
      'set'
      '  TIPOVENTA = :TIPOVENTA,'
      '  ESTACION = :ESTACION,'
      '  FOLIO = :FOLIO,'
      '  ISLA = :ISLA,'
      '  BOMBA = :BOMBA,'
      '  FECHA = :FECHA,'
      '  TURNO = :TURNO,'
      '  HORA = :HORA,'
      '  CLIENTE = :CLIENTE,'
      '  VEHICULO = :VEHICULO,'
      '  COMBUSTIBLE = :COMBUSTIBLE,'
      '  PRECIO = :PRECIO,'
      '  LITROS = :LITROS,'
      '  IMPORTECMB = :IMPORTECMB,'
      '  IMPORTEOTR = :IMPORTEOTR,'
      '  TOTAL = :TOTAL,'
      '  ESTATUS = :ESTATUS,'
      '  DESPACHADOR = :DESPACHADOR,'
      '  INDICE = :INDICE,'
      '  KILOMETRAJE = :KILOMETRAJE,'
      '  POSCARGA = :POSCARGA,'
      '  TASAIVA = :TASAIVA,'
      '  TURNOLIQ = :TURNOLIQ,'
      '  FACTURADO = :FACTURADO,'
      '  ESTACIONFAC = :ESTACIONFAC,'
      '  SERIEFAC = :SERIEFAC,'
      '  FOLIOFAC = :FOLIOFAC,'
      '  ENLINEA = :ENLINEA,'
      '  FOLIOFUERALINEA = :FOLIOFUERALINEA,'
      '  MODOCARGA = :MODOCARGA,'
      '  FECHAFACTURA = :FECHAFACTURA,'
      '  SUBCODIGO = :SUBCODIGO,'
      '  FOLIOVOLUMETRICO = :FOLIOVOLUMETRICO,'
      '  ESTADOCUENTA = :ESTADOCUENTA,'
      '  TIPOPAGO = :TIPOPAGO,'
      '  LIQUIDADO = :LIQUIDADO,'
      '  BOUCHER = :BOUCHER,'
      '  FOLIOTRANGAS = :FOLIOTRANGAS,'
      '  TIPOVENTATRANGAS = :TIPOVENTATRANGAS,'
      '  APLICADOGAS = :APLICADOGAS,'
      '  FOLIOCAR = :FOLIOCAR,'
      '  CAJA = :CAJA,'
      '  INDICEVALE = :INDICEVALE'
      'where'
      '  TIPOVENTA = :OLD_TIPOVENTA and'
      '  ESTACION = :OLD_ESTACION and'
      '  FOLIO = :OLD_FOLIO')
    InsertSQL.Strings = (
      'insert into DGASTRAN'
      
        '  (TIPOVENTA, ESTACION, FOLIO, ISLA, BOMBA, FECHA, TURNO, HORA, ' +
        'CLIENTE, '
      
        '   VEHICULO, COMBUSTIBLE, PRECIO, LITROS, IMPORTECMB, IMPORTEOTR' +
        ', '
      'TOTAL, '
      
        '   ESTATUS, DESPACHADOR, INDICE, KILOMETRAJE, POSCARGA, TASAIVA,' +
        ' '
      'TURNOLIQ, '
      '   FACTURADO, ESTACIONFAC, SERIEFAC, FOLIOFAC, ENLINEA, '
      'FOLIOFUERALINEA, '
      '   MODOCARGA, FECHAFACTURA, SUBCODIGO, FOLIOVOLUMETRICO, '
      'ESTADOCUENTA, '
      
        '   TIPOPAGO, LIQUIDADO, BOUCHER, FOLIOTRANGAS, TIPOVENTATRANGAS,' +
        ' '
      'APLICADOGAS, '
      '   FOLIOCAR, CAJA, INDICEVALE)'
      'values'
      
        '  (:TIPOVENTA, :ESTACION, :FOLIO, :ISLA, :BOMBA, :FECHA, :TURNO,' +
        ' :HORA, '
      
        '   :CLIENTE, :VEHICULO, :COMBUSTIBLE, :PRECIO, :LITROS, :IMPORTE' +
        'CMB, '
      ':IMPORTEOTR, '
      
        '   :TOTAL, :ESTATUS, :DESPACHADOR, :INDICE, :KILOMETRAJE, :POSCA' +
        'RGA, '
      ':TASAIVA, '
      
        '   :TURNOLIQ, :FACTURADO, :ESTACIONFAC, :SERIEFAC, :FOLIOFAC, :E' +
        'NLINEA, '
      '   :FOLIOFUERALINEA, :MODOCARGA, :FECHAFACTURA, :SUBCODIGO, '
      ':FOLIOVOLUMETRICO, '
      
        '   :ESTADOCUENTA, :TIPOPAGO, :LIQUIDADO, :BOUCHER, :FOLIOTRANGAS' +
        ', '
      ':TIPOVENTATRANGAS, '
      '   :APLICADOGAS, :FOLIOCAR, :CAJA, :INDICEVALE)')
    DeleteSQL.Strings = (
      'delete from DGASTRAN'
      'where'
      '  TIPOVENTA = :OLD_TIPOVENTA and'
      '  ESTACION = :OLD_ESTACION and'
      '  FOLIO = :OLD_FOLIO')
    Left = 143
    Top = 181
  end
