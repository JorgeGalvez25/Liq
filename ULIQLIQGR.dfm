  object QL_Liqg: TQuery
    OnCalcFields = QL_LiqgCalcFields
    DatabaseName = 'DBGASOL1'
    SQL.Strings = (
      
        'Select Estacion,Isla,Folio,turno,Fecha,Despachador,Totgas,Totalm' +
        'a,totgral,totpago,'
      
        '         (Select Nombre from DGASDESP where clave=DGASLIQG.Despa' +
        'chador) As NombreDesp'
      ' from DGASLIQG'
      'where Estacion=:pEstacion and'
      '                 Caja=:pCaja and'
      '              Fecha=:pFecha and '
      '               Turno=:pTurno'
      'order by Isla,Despachador')
    Left = 320
    Top = 268
    ParamData = <
      item
        DataType = ftInteger
        Name = 'pEstacion'
        ParamType = ptUnknown
      end
      item
        DataType = ftInteger
        Name = 'pCaja'
        ParamType = ptUnknown
      end
      item
        DataType = ftDateTime
        Name = 'pFecha'
        ParamType = ptUnknown
      end
      item
        DataType = ftInteger
        Name = 'pTurno'
        ParamType = ptUnknown
      end>
