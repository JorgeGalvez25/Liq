  object USQL_TurcF: TUpdateSQL
    ModifySQL.Strings = (
      'update DGASTURCF'
      'set'
      '  ESTACION = :ESTACION,'
      '  CAJA = :CAJA,'
      '  FECHA = :FECHA,'
      '  TURNO = :TURNO,'
      '  NOFICHA = :NOFICHA,'
      '  FOLIO_FICHA = :FOLIO_FICHA,'
      '  TOTAL_FICHA = :TOTAL_FICHA'
      'where'
      '  ESTACION = :OLD_ESTACION and'
      '  CAJA = :OLD_CAJA and'
      '  FECHA = :OLD_FECHA and'
      '  TURNO = :OLD_TURNO and'
      '  NOFICHA = :OLD_NOFICHA')
    InsertSQL.Strings = (
      'insert into DGASTURCF'
      
        '  (ESTACION, CAJA, FECHA, TURNO, NOFICHA, FOLIO_FICHA, TOTAL_FIC' +
        'HA)'
      'values'
      '  (:ESTACION, :CAJA, :FECHA, :TURNO, :NOFICHA, :FOLIO_FICHA, '
      ':TOTAL_FICHA)')
    DeleteSQL.Strings = (
      'delete from DGASTURCF'
      'where'
      '  ESTACION = :OLD_ESTACION and'
      '  CAJA = :OLD_CAJA and'
      '  FECHA = :OLD_FECHA and'
      '  TURNO = :OLD_TURNO and'
      '  NOFICHA = :OLD_NOFICHA')
    Left = 40
    Top = 168
  end
