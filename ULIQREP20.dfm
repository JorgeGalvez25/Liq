  object QL_Dliqp: TQuery
    DatabaseName = 'DBGASOL1'
    SQL.Strings = (
      'select fecha,sum(importe) as total from dgasdliqp'
      'where fecha>=:pfechaini and fecha<=:pfechafin'
      ' and (clave_pago='#39'01'#39' or clave_pago='#39'02'#39')'
      'group by fecha'
      '')
    Left = 8
    Top = 8
    ParamData = <
      item
        DataType = ftDateTime
        Name = 'pfechaini'
        ParamType = ptUnknown
      end
      item
        DataType = ftDateTime
        Name = 'pfechafin'
        ParamType = ptUnknown
      end>
    object QL_DliqpFECHA: TDateTimeField
      FieldName = 'FECHA'
    end
    object QL_DliqpTOTAL: TFloatField
      FieldName = 'TOTAL'
    end
  end
