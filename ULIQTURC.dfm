  object QL_Pval: TQuery
    DatabaseName = 'DBGASOL1'
    SQL.Strings = (
      'select cliente,SubCodigo,sum(total) as Importe from dgaspval'
      
        'where Estacion=:pestacion and Caja=:pcaja and turno=:pturno and ' +
        'fecha=:pfecha'
      'group by cliente,subcodigo'
      'order by cliente,subcodigo')
    Left = 264
    Top = 350
    ParamData = <
      item
        DataType = ftInteger
        Name = 'pestacion'
        ParamType = ptUnknown
      end
      item
        DataType = ftInteger
        Name = 'pcaja'
        ParamType = ptUnknown
      end
      item
        DataType = ftInteger
        Name = 'pturno'
        ParamType = ptUnknown
      end
      item
        DataType = ftDateTime
        Name = 'pfecha'
        ParamType = ptUnknown
      end>
    object QL_PvalCLIENTE: TIntegerField
      FieldName = 'CLIENTE'
    end
    object QL_PvalIMPORTE: TFloatField
      FieldName = 'IMPORTE'
    end
    object QL_PvalSUBCODIGO: TIntegerField
      FieldName = 'SUBCODIGO'
    end
  end
