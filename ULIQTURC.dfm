  object QL_Turc: TQuery
    OnCalcFields = QL_TurcCalcFields
    DatabaseName = 'DBGASOL2'
    SQL.Strings = (
      'select t.*,'
      '(select nombre from dgasdesp '
      'where clave=t.jefe_turno) as NombreJefeTurno '
      'from DGASTURC t'
      'where t.Estacion=:pEstacion and t.Caja=:pCaja and'
      't.Fecha>=:pFechaIni and t.Fecha<=:pFechaFin'
      'order by t.fecha desc, t.turno desc')
    Left = 400
    Top = 212
    ParamData = <
      item
        DataType = ftInteger
        Name = 'pEstacion'
        ParamType = ptUnknown
      end
      item
        DataType = ftInteger
        Name = 'pCaja'
        ParamType = ptUnknown
      end
      item
        DataType = ftDateTime
        Name = 'pFechaIni'
        ParamType = ptUnknown
      end
      item
        DataType = ftDateTime
        Name = 'pFechaFin'
        ParamType = ptUnknown
      end>
