  object QL_Caja: TQuery
    DatabaseName = 'DBGASOL2'
    SQL.Strings = (
      'Select Caja,Descripcion,VarIni from DGASCAJA'
      'Where Tipo='#39'Liquidacion'#39' and Estacion=:pestacion'
      'Order By Caja')
