  object QL_Pval: TQuery
    DatabaseName = 'DBGASOL1'
    SQL.Strings = (
      
        'select Cliente,SerieFac,FolioFac,FechaFactura,Sum(Total) as tota' +
        'l from dgaspval'
      'where seriefac=:pseriefac'
      'Group by Cliente,SerieFac,FolioFac,FechaFActura'
      'Order by Foliofac')
    Left = 8
    Top = 160
    ParamData = <
      item
        DataType = ftString
        Name = 'pseriefac'
        ParamType = ptUnknown
      end>
    object QL_PvalCLIENTE: TIntegerField
      FieldName = 'CLIENTE'
    end
    object QL_PvalSERIEFAC: TStringField
      FieldName = 'SERIEFAC'
      Size = 2
    end
    object QL_PvalFOLIOFAC: TIntegerField
      FieldName = 'FOLIOFAC'
    end
    object QL_PvalFECHAFACTURA: TDateTimeField
      FieldName = 'FECHAFACTURA'
    end
    object QL_PvalTOTAL: TFloatField
      FieldName = 'TOTAL'
    end
  end
