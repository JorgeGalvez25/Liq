  object QL_Pval: TQuery
    DatabaseName = 'DBGASOL1'
    SQL.Strings = (
      
        'Select EstacionFac,SerieFac,FolioFac,Cliente,FechaFactura,sum(to' +
        'tal) as Total'
      'from dgaspval'
      'where EstacionFac=:pestacion and'
      'SerieFac=:pseriefac and'
      'fechafactura>=:pfechaini and fechafactura<=:pfechafin and'
      'FolioFac>=:pfolioini and FolioFac<=:pfoliofin'
      'group by estacionfac,seriefac,foliofac,Cliente,fechafactura'
      'order by foliofac')
    Left = 16
    Top = 240
    ParamData = <
      item
        DataType = ftInteger
        Name = 'pestacion'
        ParamType = ptUnknown
      end
      item
        DataType = ftString
        Name = 'pseriefac'
        ParamType = ptUnknown
      end
      item
        DataType = ftDateTime
        Name = 'pfechaini'
        ParamType = ptUnknown
      end
      item
        DataType = ftDateTime
        Name = 'pfechafin'
        ParamType = ptUnknown
      end
      item
        DataType = ftInteger
        Name = 'pfolioini'
        ParamType = ptUnknown
      end
      item
        DataType = ftInteger
        Name = 'pfoliofin'
        ParamType = ptUnknown
      end>
    object QL_PvalESTACIONFAC: TIntegerField
      FieldName = 'ESTACIONFAC'
    end
    object QL_PvalSERIEFAC: TStringField
      FieldName = 'SERIEFAC'
      Size = 2
    end
    object QL_PvalFOLIOFAC: TIntegerField
      FieldName = 'FOLIOFAC'
    end
    object QL_PvalTOTAL: TFloatField
      FieldName = 'TOTAL'
      DisplayFormat = '###,###,##0.00'
    end
    object QL_PvalFECHAFACTURA: TDateTimeField
      FieldName = 'FECHAFACTURA'
    end
    object QL_PvalCLIENTE: TIntegerField
      FieldName = 'CLIENTE'
    end
  end
