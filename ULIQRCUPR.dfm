  object USQL_Rrcu: TUpdateSQL
    ModifySQL.Strings = (
      'update DGASRRCU'
      'set'
      '  ESTACION = :ESTACION,'
      '  CAJA = :CAJA,'
      '  FECHA = :FECHA,'
      '  TURNO = :TURNO,'
      '  SERIE = :SERIE,'
      '  CANTIDAD = :CANTIDAD,'
      '  IMPORTE = :IMPORTE'
      'where'
      '  ESTACION = :OLD_ESTACION and'
      '  CAJA = :OLD_CAJA and'
      '  FECHA = :OLD_FECHA and'
      '  TURNO = :OLD_TURNO and'
      '  SERIE = :OLD_SERIE')
    InsertSQL.Strings = (
      'insert into DGASRRCU'
      '  (ESTACION, CAJA, FECHA, TURNO, SERIE, CANTIDAD, IMPORTE)'
      'values'
      
        '  (:ESTACION, :CAJA, :FECHA, :TURNO, :SERIE, :CANTIDAD, :IMPORTE' +
        ')')
    DeleteSQL.Strings = (
      'delete from DGASRRCU'
      'where'
      '  ESTACION = :OLD_ESTACION and'
      '  CAJA = :OLD_CAJA and'
      '  FECHA = :OLD_FECHA and'
      '  TURNO = :OLD_TURNO and'
      '  SERIE = :OLD_SERIE')
    Left = 408
    Top = 168
  end
