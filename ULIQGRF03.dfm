  object Q_Productos: TQuery
    DatabaseName = 'DBGASOL1'
    SQL.Strings = (
      'Select Fecha, sum(a.Importe) as IMPORTE'
      'From DGASDLIQA a'
      'Where a.Estacion=:PEstacion'
      '  and a.Fecha>=:PFechaIni'
      '  and a.Fecha<=:PFechaFin'
      
        '  and exists(select m.* from dgasliqg m where m.estacion=a.estac' +
        'ion and m.folio=a.folio and m.aplicado='#39'Si'#39')'
      'group by Fecha')
    Left = 712
    Top = 272
    ParamData = <
      item
        DataType = ftUnknown
        Name = 'PEstacion'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'PFechaIni'
        ParamType = ptUnknown
      end
      item
        DataType = ftUnknown
        Name = 'PFechaFin'
        ParamType = ptUnknown
      end>
    object Q_ProductosFecha: TDateTimeField
      FieldName = 'FECHA'
    end
    object Q_ProductosIMPORTE: TFloatField
      FieldName = 'IMPORTE'
    end
  end
